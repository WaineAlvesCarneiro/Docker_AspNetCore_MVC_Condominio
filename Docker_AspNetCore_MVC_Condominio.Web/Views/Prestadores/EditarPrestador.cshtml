@model Docker_AspNetCore_MVC_Condominio.Web.Models.ImovelViewModel
@{
    ViewData["Title"] = "Editar Prestador de Serviço";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex align-items-center gap-2 mb-4 pb-2 border-bottom">
        <i class="bi bi-wrench-adjustable text-primary fs-3"></i>
        <h4 class="fw-bold text-secondary m-0">@ViewData["Title"]</h4>
    </div>

    <form asp-controller="Prestadores" asp-action="EditarPrestador" autocomplete="off">
        <input type="hidden" asp-for="Prestador!.Id" />
        <input type="hidden" asp-for="Prestador!.ImovelId" />
        <input type="hidden" asp-for="Prestador!.EmpresaId" />
        <input type="hidden" asp-for="Imovel!.Id" />
        <input type="hidden" asp-for="Imovel!.Apartamento" />
        <input type="hidden" asp-for="Imovel!.Bloco" />

        <partial name="_ImovelBlocoApto" />

        <div class="row g-4">
            <div class="col-12">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-card-heading me-1"></i> Dados de Identificação</h6>
                <div class="row g-3">
                    <div class="col-md-5">
                        <div class="form-floating">
                            <input autofocus asp-for="Prestador!.Nome" class="form-control" placeholder="Nome Completo" />
                            <label asp-for="Prestador!.Nome">Nome do Prestador</label>
                            <span asp-validation-for="Prestador!.Nome" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-floating">
                            <input asp-for="Prestador!.Documento" class="form-control" placeholder="RG ou CPF" />
                            <label asp-for="Prestador!.Documento">Documento (RG/CPF)</label>
                            <span asp-validation-for="Prestador!.Documento" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-floating">
                            <input asp-for="Prestador!.EmpresaPrestadora" class="form-control" placeholder="Empresa" />
                            <label asp-for="Prestador!.EmpresaPrestadora">Empresa / Autônomo</label>
                            <span asp-validation-for="Prestador!.EmpresaPrestadora" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-12">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-calendar-event me-1"></i> Contrato e Permanência</h6>
                <div class="row g-3">
                    <div class="col-md-2">
                        <div class="form-floating">
                            <input type="date" asp-for="Prestador.DataEntrada" asp-format="{0:yyyy-MM-dd}" class="form-control" />
                            <label asp-for="Prestador.DataEntrada">Data de Entrada</label>
                            <span asp-validation-for="Prestador.DataEntrada" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-floating">
                            <input type="date" asp-for="Prestador.DataSaida" asp-format="{0:yyyy-MM-dd}" class="form-control" />
                            <label asp-for="Prestador.DataSaida">Data de Saída</label>
                            <span asp-validation-for="Prestador.DataSaida" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4 pt-3 border-top">
            <button type="submit" class="btn btn-success px-4 shadow-sm fw-medium">
                <i class="bi bi-floppy"></i> Salvar
            </button>
            <a asp-action="ListarPrestadores" asp-route-id="@Model.Prestador!.Id" class="btn btn-secondary px-4 fw-medium">
                <i class="bi bi-x-circle"></i> Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}