@model IEnumerable<Docker_AspNetCore_MVC_Condominio.Web.Models.Imovel>
@{
    ViewData["Title"] = "Lista de Imóveis";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-houses-fill text-primary fs-3"></i>
            <h4 class="fw-bold text-secondary m-0">@ViewData["Title"]</h4>
        </div>
        @if (User.IsInRole("Sindico"))
        {
            <a asp-action="CadastrarImovel" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm fw-medium">
                <i class="bi bi-plus-circle"></i> Adicionar
            </a>
        }
    </div>

    <div class="bg-light p-3 rounded-3 border mb-4">
        <form role="search" method="get" autocomplete="off" class="row g-3 align-items-center">
            <div class="col-md-3">
                <div class="form-floating">
                    <input autofocus type="text" name="Bloco" id="txtBloco" class="form-control" placeholder="Bloco" value="@ViewData["bloco"]" />
                    <label for="txtBloco">Bloco</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-floating">
                    <input type="text" name="Apartamento" id="txtApartamento" class="form-control" placeholder="Apartamento" value="@ViewData["apartamento"]" />
                    <label for="txtApartamento">Apartamento</label>
                </div>
            </div>
            <div class="col-md-auto ms-auto">
                <button type="submit" class="btn btn-primary py-2.5 px-4 shadow-sm fw-medium d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-search"></i> Pesquisar
                </button>
            </div>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-bold">
                <tr>
                    <th>Bloco</th>
                    <th>Apartamento</th>
                    <th>Box Garagem</th>
                    <th class="text-end px-3">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            <i class="bi bi-houses-fill fs-3 d-block mb-2"></i>
                            Nenhum registro encontrado.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Bloco</td>
                            <td>@item.Apartamento</td>
                            <td>@item.BoxGaragem</td>
                            <td class="text-end px-3">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="DetalharImovel" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-2" title="Detalhar Imóvel">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Sindico"))
                                    {
                                        <a asp-action="EditarImovel" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-2" title="Editar Imóvel">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="ExcluirImovel" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-2" title="Excluir Imóvel">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>