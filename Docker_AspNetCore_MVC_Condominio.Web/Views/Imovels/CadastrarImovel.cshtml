@model Docker_AspNetCore_MVC_Condominio.Web.Models.ImovelViewModel
@{
    ViewData["Title"] = "Novo Imóvel";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex align-items-center gap-2 mb-4 pb-2 border-bottom">
        <i class="bi bi-house-add-fill text-primary fs-3"></i>
        <h4 class="fw-bold text-secondary m-0">@ViewData["Title"]</h4>
    </div>

    <form asp-action="CadastrarImovel" autocomplete="off">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="row g-4">
            <div class="col-12">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-geo-alt-fill me-1"></i> Localização da Unidade</h6>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="form-floating">
                            <input autofocus asp-for="Imovel!.Bloco" class="form-control" placeholder="Bloco" />
                            <label asp-for="Imovel!.Bloco">Bloco</label>
                            <span asp-validation-for="Imovel!.Bloco" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating">
                            <input asp-for="Imovel!.Apartamento" class="form-control" placeholder="Apartamento" />
                            <label asp-for="Imovel!.Apartamento">Apartamento</label>
                            <span asp-validation-for="Imovel!.Apartamento" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating">
                            <input asp-for="Imovel!.BoxGaragem" class="form-control" placeholder="Box" />
                            <label asp-for="Imovel!.BoxGaragem">Box Garagem</label>
                            <span asp-validation-for="Imovel!.BoxGaragem" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4 pt-3 border-top">
            <button type="submit" class="btn btn-success px-4 shadow-sm">
                <i class="bi bi-floppy"></i> Salvar
            </button>
            <a asp-action="ListarImoveis" class="btn btn-secondary px-4">
                <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}