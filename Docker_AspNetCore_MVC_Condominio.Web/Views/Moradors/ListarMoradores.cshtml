@model IEnumerable<Docker_AspNetCore_MVC_Condominio.Web.Models.Morador>
@{
    ViewData["Title"] = "Lista de Moradores";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex justify-content-between align-items-center mb-2 pb-1 border-bottom">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-people text-primary fs-3"></i>
            <h4 class="fw-bold text-secondary m-0">@ViewData["Title"]</h4>
        </div>
        <div class="text-danger small d-flex align-items-center gap-2 bg-danger-subtle text-danger-emphasis px-3 py-2 rounded-2 border border-danger-subtle">
            <i class="bi bi-info-circle-fill fs-6 text-danger"></i>
            <span>Para cadastrar um novo morador, acesse a tela de <strong>Detalhes do Imóvel</strong> correspondente.</span>
        </div>
    </div>

    <div class="bg-light p-3 rounded-3 border mb-4">
        <form role="search" method="get" autocomplete="off" class="row g-3 align-items-center">
            <div class="col-md-3">
                <div class="form-floating">
                    <input autofocus type="text" name="morador" id="txtMorador" class="form-control" placeholder="Nome do morador" value="@ViewData["morador"]" />
                    <label for="txtMorador">Nome do Morador</label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-check form-switch mb-2 h-100 d-flex align-items-center gap-2">
                    @Html.CheckBox("saida", ViewData["comDataSaida"] as bool? ?? false, new { @class = "form-check-input", id = "chkSaida" })
                    <label class="form-check-label text-secondary small fw-medium" for="chkSaida">
                        Filtrar com data de saída preenchida
                    </label>
                </div>
            </div>
            <div class="col-md-auto ms-auto">
                <button type="submit" class="btn btn-primary py-2.5 px-4 shadow-sm fw-medium d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-search"></i> Pesquisar
                </button>
            </div>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-bold">
                <tr>
                    <th>Imóvel</th>
                    <th>Nome Completo</th>
                    <th>Celular</th>
                    <th>Proprietário</th>
                    <th>Data Entrada</th>
                    <th>Data Saída</th>
                    <th class="text-end px-3">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="bi bi-people fs-3 d-block mb-2"></i>
                            Nenhum registro encontrado.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-light text-dark border font-monospace fs-6">Bloco: @item.Imovel!.Bloco</span>
                                <span class="badge bg-light text-dark border font-monospace fs-6">Apto: @item.Imovel!.Apartamento</span>
                            </td>
                            <td>@item.Nome</td>
                            <td><i class="bi bi-whatsapp text-success me-1"></i> @item.Celular</td>
                            <td>
                                <span class="badge @(item.Proprietario == 1 ?
                                    "bg-primary-subtle text-primary border border-primary-subtle" : "bg-info-subtle text-info border border-info-subtle") px-3 py-2 fs-6">
                                    @(item.Proprietario == 1 ? "Proprietário" : "Inquilino")
                                </span>
                            </td>
                            <td>@item.DataEntrada.ToShortDateString()</td>
                            <td>
                                <span class="badge @(item.DataSaida == null ?
                                    "bg-success-subtle text-success border border-success-subtle" : "bg-danger-subtle text-danger border border-danger-subtle")  px-3 py-2 fs-6">
                                    @(item.DataSaida == null ? "-Sem Saída-" : item.DataSaida.Value.ToShortDateString())
                                </span>
                            </td>
                            <td class="text-end px-3">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="DetalharMorador" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-2" title="Detalhar Morador">
                                        <i class="bi bi bi-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Sindico"))
                                    {
                                        <a asp-action="EditarMorador" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-2" title="Editar Morador">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="ExcluirMorador" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-2" title="Excluir Morador">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>