@model IEnumerable<Docker_AspNetCore_MVC_Condominio.Web.Models.EncomendasEntregues>
@{
    ViewData["Title"] = "Lista de Encomendas Entregues";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-box-seam text-primary fs-3"></i>
            <h4 class="fw-bold text-secondary m-0">@ViewData["Title"]</h4>
        </div>
        <div class="text-danger small d-flex align-items-center gap-2 bg-danger-subtle text-danger-emphasis px-3 py-2 rounded-2 border border-danger-subtle">
            <i class="bi bi-info-circle-fill fs-6 text-danger"></i>
            <span>Para cadastrar uma encomenda entregue, acesse a tela de <strong>Detalhes do Imóvel</strong> correspondente.</span>
        </div>
    </div>

    <div class="bg-light p-3 rounded-3 border mb-4">
        <form role="search" method="get" autocomplete="off" class="row g-3 align-items-center">
            <div class="col-md-3">
                <div class="form-floating">
                    <input autofocus type="text" name="codigorastreio" id="txtRecebida" class="form-control" placeholder="Código Rastreio" value="@ViewData["codigorastreio"]" />
                    <label for="txtRecebida">Código Rastreio</label>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-check form-switch mb-2 h-100 d-flex align-items-center gap-2">
                    @Html.CheckBox("entregue", ViewData["comdataentregue"] as bool? ?? false, new { @class = "form-check-input", id = "chkEntregue" })
                    <label class="form-check-label text-secondary small fw-medium" for="chkEntregue">
                        Filtrar encomendas entregue
                    </label>
                </div>
            </div>
            <div class="col-md-auto ms-auto">
                <button type="submit" class="btn btn-primary py-2.5 px-4 shadow-sm fw-medium d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-search"></i> Pesquisar
                </button>
            </div>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-bold">
                <tr>
                    <th>Imóvel</th>
                    <th>Morador na Encomenda</th>
                    <th>Código Rastreio</th>
                    <th>Data do Recebimento</th>
                    <th>Entregue?</th>
                    <th>Entregue ao Morador</th>
                    <th>Data da Entrega</th>
                    <th class="text-end px-3">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted py-4">
                            <i class="bi bi-box-seam fs-3 d-block mb-2"></i>
                            Nenhum registro encontrado.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-light text-dark border font-monospace fs-6">Bloco: @item.Imovel!.Bloco</span>
                                <span class="badge bg-light text-dark border font-monospace fs-6">Apto: @item.Imovel!.Apartamento</span>
                            </td>
                            <td>@item.EncomendasRecebidas!.Morador!.Nome</td>
                            <td>@item.EncomendasRecebidas!.CodigoRastreio</td>
                            <td>@item.EncomendasRecebidas!.DataRecebimento.ToShortDateString()</td>
                            <td>
                                <span class="badge @(item.EncomendasRecebidas!.Entregue ?
                                    "bg-success-subtle text-success border border-success-subtle" : "bg-danger-subtle text-danger border border-danger-subtle")  px-3 py-2 fs-6">
                                    @(item.EncomendasRecebidas!.Entregue ? "Sim" : "Não")
                                </span>
                            </td>
                            <td>@item.Morador!.Nome</td>
                            <td>@item.DataEntrega.ToShortDateString()</td>
                            <td class="text-end px-3">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="DetalharEntrega" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-2" title="Detalhar Encomenda Entregue">
                                        <i class="bi bi bi-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Sindico"))
                                    {
                                        <a asp-action="EditarEntrega" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-2" title="Editar Encomenda Entregue">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="ExcluirEntrega" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-2" title="Excluir Encomenda Entregue">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>