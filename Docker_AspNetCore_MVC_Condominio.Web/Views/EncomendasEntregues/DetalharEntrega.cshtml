@model Docker_AspNetCore_MVC_Condominio.Web.Models.ImovelViewModel
@{
    ViewData["Title"] = "Dados da Encomenda Entregue";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-box-seam text-primary fs-3"></i>
            <h4 class="fw-bold text-secondary m-0">@ViewData["Title"]</h4>
        </div>
    </div>

    <partial name="_ImovelBlocoApto" />

    <div class="row g-4">
        <div class="col-12 border-bottom pb-3">
            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-file-earmark-person me-1"></i> Dados Gerais da Encomenda Recebida</h6>
            <div class="row g-3">
                <div class="col-md-3">
                    <small class="text-muted d-block">Código Rastreio</small>
                    <span class="fw-semibold text-dark fs-8">@Model.EncomendasRecebidas!.CodigoRastreio</span>
                </div>
                <div class="col-md-4">
                    <small class="text-muted d-block">Nome Completo</small>
                    <span class="fw-semibold text-dark fs-8">@Model.Morador!.Nome</span>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Data de Entrada</small>
                    <span class="text-dark d-block mt-1 fw-medium">@Model.EncomendasRecebidas!.DataRecebimento.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="col-md-2">
                    <small class="text-muted d-block">Entregue?</small>
                    <span class="badge @(Model.EncomendasRecebidas!.Entregue ? "bg-success-subtle text-success border border-success-subtle" : "bg-danger-subtle text-danger border border-danger-subtle") px-2 py-1.5 rounded mt-1 fs-7">
                        @(Model.EncomendasRecebidas!.Entregue ? "Sim" : "Não")
                    </span>
                </div>
            </div>
        </div>
        <div class="col-12 border-bottom pb-3">
            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-file-earmark-person me-1"></i> Dados da Encomenda Entregue</h6>
            <div class="row g-3">
                <div class="col-md-4">
                    <small class="text-muted d-block">Nome Completo</small>
                    <span class="fw-semibold text-dark fs-8">@Model.EncomendasEntregues!.Morador!.Nome</span>
                </div>
                <div class="col-md-3">
                    <small class="text-muted d-block">Data da Entrega</small>
                    <span class="text-dark d-block mt-1 fw-medium">@Model.EncomendasEntregues!.DataEntrega.ToString("dd/MM/yyyy")</span>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 mt-1 pt-3">
            <a asp-action="ListarEntregas" class="btn btn-secondary px-4">
                <i class="bi bi-arrow-left-circle me-1"></i> Voltar para Lista
            </a>
        </div>
    </div>
</div>