@model Docker_AspNetCore_MVC_Condominio.Web.Models.ImovelViewModel
@{
    ViewData["Title"] = "Entrega de Encomenda";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex align-items-center gap-2 mb-4 pb-2 border-bottom">
        <i class="bi bi-box-seam text-primary fs-3"></i>
        <h4 class="fw-bold text-secondary m-0">@ViewData["Title"]</h4>
    </div>

    <form asp-controller="EncomendasEntregues" asp-action="CadastrarEntrega" autocomplete="off">
        <input type="hidden" asp-for="Imovel!.Id" />
        <input type="hidden" asp-for="Imovel!.BoxGaragem" />
        <input type="hidden" asp-for="Imovel!.Apartamento" />
        <input type="hidden" asp-for="Imovel!.Bloco" />
        <input type="hidden" asp-for="Imovel!.EmpresaId" />
        <input type="hidden" asp-for="EncomendasEntregues.EncomendasRecebidasId" />

        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <partial name="_ImovelBlocoApto" />

        <div class="row g-4">
            <div class="col-md-3">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-truck me-1"></i> Dados da Encomenda</h6>
                <div class="form-floating">
                    <input asp-for="EncomendasRecebidas.CodigoRastreio" class="form-control" placeholder="Código Rastreio" readonly />
                    <label asp-for="EncomendasRecebidas.CodigoRastreio">Código Rastreio</label>
                    <span asp-validation-for="EncomendasRecebidas.CodigoRastreio" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-5">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-people me-1"></i> Morador na Encomenda</h6>
                <div class="form-floating">
                    <select asp-for="EncomendasRecebidas.MoradorId" asp-items="@(new SelectList(Model.Moradores, "Id", "Nome"))" class="form-select py-2-5" disabled>
                        <option value="">-- Selecione um Morador --</option>
                    </select>
                    <span asp-validation-for="EncomendasRecebidas.MoradorId" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-2">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-calendar me-1"></i> Data do Recebimento</h6>
                <div class="form-floating">
                    <input type="date" asp-for="EncomendasRecebidas.DataRecebimento" asp-format="{0:yyyy-MM-dd}" class="form-control" readonly />
                    <label asp-for="EncomendasRecebidas.DataRecebimento">Data de Entrada</label>
                    <span asp-validation-for="EncomendasRecebidas.DataRecebimento" class="text-danger small"></span>
                </div>
            </div>

            <div class="col-md-5">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-people me-1"></i> Vincular Encomenda ao Morador</h6>
                <div class="form-floating">
                    <select autofocus asp-for="EncomendasEntregues.MoradorId" asp-items="@(new SelectList(Model.Moradores, "Id", "Nome"))" class="form-select py-2-5">
                        <option value="">-- Selecione um Morador --</option>
                    </select>
                    <span asp-validation-for="EncomendasEntregues.MoradorId" class="text-danger small"></span>
                </div>
            </div>
            <div class="col-md-2">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-calendar me-1"></i> Data da Entrega</h6>
                <div class="form-floating">
                    <input type="date" asp-for="EncomendasEntregues.DataEntrega" class="form-control" />
                    <label asp-for="EncomendasEntregues.DataEntrega">Data de Entrada</label>
                    <span asp-validation-for="EncomendasEntregues.DataEntrega" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2 mt-4 pt-3 border-top">
                <button type="submit" class="btn btn-success px-4 shadow-sm fw-medium">
                    <i class="bi bi-floppy"></i> Salvar
                </button>
                <a asp-controller="Imovels" asp-action="DetalharImovel" asp-route-id="@Model.Imovel!.Id" class="btn btn-secondary px-4 fw-medium">
                    <i class="bi bi-x-circle me-1"></i> Cancelar
                </a>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
