@model Docker_AspNetCore_MVC_Condominio.Web.Models.ImovelViewModel
@{
    ViewData["Title"] = "Aviso Crítico de Exclusão";
}

<div class="row justify-content-center align-items-center" style="min-height: 65vh;">
    <div class="col-xl-5 col-lg-7 col-md-9 col-sm-12">
        <div class="card shadow border-0 rounded-3 bg-white">
            <div class="card-body p-5 text-center">
                <div class="display-4 text-danger mb-3">
                    <i class="bi bi-person-dash-fill"></i>
                </div>

                <h4 class="fw-bold text-secondary mb-2">Excluir Visitante?</h4>
                <p class="text-muted small mb-4">
                    Esta ação é irreversível e removerá permanentemente o histórico do fluxo deste visitante das portarias. Tem certeza que deseja prosseguir?
                </p>

                @if (Model.Visitante != null)
                {
                    <div class="bg-light rounded-3 p-3 border text-start mb-4 font-monospace small">
                        <div><strong>Nome do Visitante:</strong> @Model.Visitante.Nome</div>
                    </div>
                }

                <form asp-controller="Visitantes" asp-action="ExcluirVisitante" method="post">
                    <input type="hidden" asp-for="Visitante!.Id" />
                    <input type="hidden" asp-for="Imovel!.Id" />

                    <div class="d-flex justify-content-center gap-3">
                        <a asp-controller="Visitantes" asp-action="ListarVisitantes" class="btn btn-secondary px-4 fw-medium">
                            Não, Cancelar
                        </a>
                        <button type="submit" class="btn btn-danger px-4 shadow-sm fw-medium">
                            Sim, Confirmar Exclusão
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>