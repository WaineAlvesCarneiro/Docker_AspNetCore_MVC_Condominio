@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    ViewData["Title"] = "Perfis de Acesso (Roles)";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-shield-lock-fill text-primary fs-3"></i>
            <h4 class="fw-bold text-secondary m-0">@ViewData["Title"]</h4>
        </div>
        <a asp-action="CriarRole" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm fw-medium">
            <i class="bi bi-plus-circle"></i> Adicionar Perfil
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="text-muted small fw-bold text-uppercase px-3" style="width: 40%;">ID do Perfil</th>
                    <th class="text-muted small fw-bold text-uppercase px-3">Nome do Perfil (Role)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-secondary small font-monospace px-3">
                            @Html.DisplayFor(modelItem => item.Id)
                        </td>
                        <td class="fw-semibold text-dark px-3">
                            <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1.5 rounded">
                                @Html.DisplayFor(modelItem => item.Name)
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>