@model Docker_AspNetCore_MVC_Condominio.Web.Models.Empresa
@{
    ViewData["Title"] = "Editar Empresa do Condomínio";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex align-items-center gap-2 mb-4 pb-2 border-bottom">
        <i class="bi bi-pencil-square text-primary fs-3"></i>
        <h4 class="fw-bold text-secondary m-0">@ViewData["Title"]</h4>
    </div>

    <form asp-action="EditarEmpresa" autocomplete="off">
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="row g-4">
            <div class="col-12">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-info-circle me-1"></i> Dados Gerais</h6>
                <div class="row g-3">
                    <div class="col-md-5">
                        <div class="form-floating">
                            <input autofocus asp-for="RazaoSocial" class="form-control" placeholder="Razão Social" />
                            <label asp-for="RazaoSocial">Razão Social</label>
                            <span asp-validation-for="RazaoSocial" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-floating">
                            <input asp-for="Cnpj" class="form-control" placeholder="CNPJ" id="cnpj" />
                            <label asp-for="Cnpj">CNPJ</label>
                            <span asp-validation-for="Cnpj" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-12 mt-3">
                        <label class="form-label text-muted small fw-semibold d-block mb-2">Tipo de Condomínio</label>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" value="1" asp-for="TipoDeCondominio" id="tipoAp" checked />
                            <label class="form-check-label text-dark" for="tipoAp">Apartamentos</label>
                        </div>
                        <div class="form-check form-check-inline">
                            <input class="form-check-input" type="radio" value="2" asp-for="TipoDeCondominio" id="tipoCasa" />
                            <label class="form-check-label text-dark" for="tipoCasa">Casas</label>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-person-badge me-1"></i> Dados do Responsável</h6>
                <div class="row g-3">
                    <div class="col-md-5">
                        <div class="form-floating">
                            <input asp-for="NomeResponsavel" class="form-control" placeholder="Nome do Responsável" />
                            <label asp-for="NomeResponsavel">Nome Completo</label>
                            <span asp-validation-for="NomeResponsavel" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-floating">
                            <input asp-for="Celular" class="form-control" placeholder="Celular" id="celular" />
                            <label asp-for="Celular">Celular</label>
                            <span asp-validation-for="Celular" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-floating">
                            <input asp-for="Email" class="form-control" placeholder="E-mail" />
                            <label asp-for="Email">E-mail</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-geo-alt me-1"></i> Dados de Endereço</h6>
                <div class="row g-3">
                    <div class="col-md-2">
                        <div class="form-floating">
                            <input asp-for="Cep" class="form-control" placeholder="CEP" id="cep" />
                            <label asp-for="Cep">CEP</label>
                            <span asp-validation-for="Cep" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="form-floating">
                            <input asp-for="Uf" class="form-control" placeholder="UF" readonly />
                            <label asp-for="Uf">UF</label>
                            <span asp-validation-for="Uf" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="form-floating">
                            <input asp-for="Cidade" class="form-control" placeholder="Cidade" readonly />
                            <label asp-for="Cidade">Cidade</label>
                            <span asp-validation-for="Cidade" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Endereco" class="form-control" placeholder="Endereço" readonly />
                            <label asp-for="Endereco">Endereço (Rua, Av.)</label>
                            <span asp-validation-for="Endereco" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-floating">
                            <input asp-for="Bairro" class="form-control" placeholder="Bairro" readonly />
                            <label asp-for="Bairro">Bairro</label>
                            <span asp-validation-for="Bairro" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Complemento" class="form-control" placeholder="Complemento" />
                            <label asp-for="Complemento">Complemento (Opcional)</label>
                            <span asp-validation-for="Complemento" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4 pt-3 border-top">
            <button type="submit" class="btn btn-success px-4 shadow-sm">
                <i class="bi bi-floppy"></i> Salvar
            </button>
            <a asp-action="ListarEmpresas" class="btn btn-secondary px-4">
                <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(function(){
            $('#cnpj').mask('00.000.000/0000-00');
            $('#celular').mask('(00) 00000-0000');
            $('#cep').mask('00.000-000');
        });
    </script>

    <script>
            document.getElementById("cep").addEventListener("blur", async function () {
            let cep = this.value.replace(/\D/g, '');
            if (!cep) return;

            try {
                const response = await fetch(`/BuscarCep/BuscarCep?cep=${cep}`);
                if (!response.ok) {
                    alert("Erro ao buscar CEP");
                    return;
                }

                const data = await response.json();

                if (data.error) {
                    alert(data.error);
                    return;
                }

                document.getElementById("Uf").value = data.uf;
                document.getElementById("Cidade").value = data.cidade;
                document.getElementById("Endereco").value = data.endereco;
                document.getElementById("Bairro").value = data.bairro;
            } catch (err) {
                alert("Erro de conexão com serviço de CEP");
            }
        });

    </script>
}