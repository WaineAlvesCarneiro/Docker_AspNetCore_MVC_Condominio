@using Docker_AspNetCore_MVC_Condominio.Web.Helper
@model Docker_AspNetCore_MVC_Condominio.Web.Models.Empresa
@{
    ViewData["Title"] = "Detalhes da Empresa";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div class="d-flex align-items-center gap-2 text-secondary">
            <i class="bi bi-buildings text-primary fs-3"></i>
            <h4 class="fw-bold m-0">@ViewData["Title"]</h4>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 border-bottom pb-3">
            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-info-circle me-1"></i> Dados Gerais</h6>
            <div class="row g-3">
                <div class="col-md-4 col-sm-6"><small class="text-muted d-block fw-normal">Razão Social</small>@Model.RazaoSocial</div>
                <div class="col-md-2 col-sm-6"><small class="text-muted d-block fw-normal">CNPJ</small>@MascaraHelper.FormatarCnpj(@Model.Cnpj)</div>
                <div class="col-md-2 col-sm-6">
                    <small class="text-muted d-block fw-normal">Tipo de Condomínio</small>
                    <span class="badge @(Model.TipoDeCondominio == 1 ? "bg-info-subtle text-info border border-info-subtle" : "bg-warning-subtle text-warning border border-warning-subtle") px-2 py-1 small mt-1 fw-bold">
                        @(Model.TipoDeCondominio == 1 ? "Apartamentos" : "Casas")
                    </span>
                </div>
            </div>
        </div>

        <div class="col-12 border-bottom pb-3">
            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-person-badge me-1"></i> Dados do Responsável</h6>
            <div class="row g-3">
                <div class="col-md-5 col-sm-6"><small class="text-muted d-block fw-normal">Nome Completo</small>@Model.NomeResponsavel</div>
                <div class="col-md-2 col-sm-6"><small class="text-muted d-block fw-normal">Celular</small><i class="bi bi-whatsapp text-success me-1"></i>@MascaraHelper.FormatarCelular(@Model.Celular)</div>
                <div class="col-md-5 col-sm-6"><small class="text-muted d-block fw-normal">E-mail de Contato</small>@Model.Email</div>
            </div>
        </div>

        <div class="col-12 border-bottom pb-3">
            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-geo-alt me-1"></i> Endereço e Localização</h6>
            <div class="row g-3">
                <div class="col-md-1 col-sm-2"><small class="text-muted d-block fw-normal">CEP</small>@MascaraHelper.FormatarCep(@Model.Cep)</div>
                <div class="col-md-4 col-sm-5"><small class="text-muted d-block fw-normal">Cidade - UF</small>@Model.Cidade - @Model.Uf</div>
                <div class="col-md-5 col-sm-8"><small class="text-muted d-block fw-normal">Logradouro Endereço</small>@Model.Endereco</div>
                <div class="col-md-5 col-sm-4"><small class="text-muted d-block fw-normal">Bairro</small>@Model.Bairro</div>
                <div class="col-md-4 col-sm-6"><small class="text-muted d-block fw-normal">Complemento</small>@(Model.Complemento ?? "-")</div>
            </div>
        </div>
    </div>

    <div class="d-flex pt-2">
        <a asp-action="ListarEmpresas" class="btn btn-secondary px-4">
            <i class="bi bi-arrow-left-circle me-1"></i> Voltar para Lista
        </a>
    </div>
</div>