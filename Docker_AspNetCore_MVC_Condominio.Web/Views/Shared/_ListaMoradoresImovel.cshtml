@model Docker_AspNetCore_MVC_Condominio.Web.Models.ImovelViewModel

<div class="card border-0 shadow-sm rounded-3 bg-white mt-3">
    <div class="table-responsive">
        <h6 class="fw-bold text-primary mb-3"><i class="bi bi-people-fill me-1"></i> Moradores Vinculados ao Imóvel</h6>
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="text-muted small fw-bold text-uppercase px-3">Nome Completo</th>
                    <th class="text-muted small fw-bold text-uppercase px-3">Celular</th>
                    <th class="text-muted small fw-bold text-uppercase px-3">E-mail</th>
                    <th class="text-muted small fw-bold text-uppercase px-3">Proprietário</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Moradores != null && Model.Moradores.Any())
                {
                    @foreach (var obj in Model.Moradores)
                    {
                        <tr>
                            <td class="fw-semibold text-dark px-3">
                                @Html.DisplayFor(modelItem => obj.Nome)
                            </td>
                            <td class="text-dark px-3">
                                <i class="bi bi-whatsapp text-success me-1"></i> @Html.DisplayFor(modelItem => obj.Celular)
                            </td>
                            <td class="text-dark px-3">
                                @Html.DisplayFor(modelItem => obj.Email)
                            </td>
                            <td class="text-dark px-3">
                                <span class="badge @(obj.Proprietario == 1 ? "bg-primary-subtle text-primary border border-primary-subtle" : "bg-info-subtle text-info border border-info-subtle") px-2 py-1 rounded">
                                    @(obj.Proprietario == 1 ? "Proprietário" : "Inquilino")
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">
                            <i class="bi bi-people text-secondary fs-3 d-block mb-2"></i>
                            <span class="small">Nenhum morador cadastrado e ativo para este imóvel até o momento.</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>