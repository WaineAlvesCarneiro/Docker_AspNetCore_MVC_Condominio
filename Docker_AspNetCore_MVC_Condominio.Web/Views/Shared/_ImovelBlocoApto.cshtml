@model Docker_AspNetCore_MVC_Condominio.Web.Models.ImovelViewModel
<div class="mb-3">
    <div class="row g-1">
        <div class="col-md-6">
            <div class="p-3 bg-light rounded-3 border h-100">
                <h6 class="fw-bold text-secondary mb-3">
                    <i class="bi bi-geo-alt-fill text-primary me-1"></i> Localização da Unidade
                </h6>
                <div class="row g-2">
                    <div class="col-4">
                        <small class="text-muted d-block">Bloco</small>
                        <span class="fw-bold text-dark fs-6">@Model.Imovel?.Bloco</span>
                    </div>
                    <div class="col-4">
                        <small class="text-muted d-block">Apartamento</small>
                        <span class="fw-bold text-dark fs-6">@Model.Imovel?.Apartamento</span>
                    </div>
                    <div class="col-4">
                        <small class="text-muted d-block">Box Garagem</small>
                        <span class="fw-bold text-dark fs-6">@(Model.Imovel?.BoxGaragem ?? "Nenhum")</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>