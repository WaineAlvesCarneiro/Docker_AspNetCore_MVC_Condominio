@model Docker_AspNetCore_MVC_Condominio.Web.Models.ImovelViewModel
@{
    ViewData["Title"] = "Aviso Crítico de Exclusão";
}

<div class="row justify-content-center align-items-center" style="min-height: 65vh;">
    <div class="col-xl-5 col-lg-7 col-md-9 col-sm-12">
        <div class="card shadow border-0 rounded-3 bg-white">
            <div class="card-body p-5 text-center">
                <div class="display-4 text-danger mb-3">
                    <i class="bi bi-person-x-fill"></i>
                </div>

                <h4 class="fw-bold text-secondary mb-2">Excluir Encomenda Recebida?</h4>
                <p class="text-muted small mb-4">
                    Esta ação removerá permanentemente o registro desta Encomenda Recebida do sistema do condomínio. Tem certeza que deseja prosseguir?
                </p>

                @if (Model.EncomendasRecebidas != null)
                {
                    <div class="bg-light rounded-3 p-3 border text-start mb-4 font-monospace small">
                        <div><strong>Código Rastreio:</strong> @Model.EncomendasRecebidas.CodigoRastreio</div>
                        <div><strong>Nome do Morador na Encomenda:</strong> @Model.EncomendasRecebidas.Morador!.Nome</div>
                    </div>
                }

                <form asp-action="ExcluirRecebida" method="post">
                    <input type="hidden" asp-for="EncomendasRecebidas!.Id" />

                    <div class="d-flex justify-content-center gap-3">
                        <a asp-action="ListarRecebidas" asp-route-id="@Model.EncomendasRecebidas!.Id" class="btn btn-secondary px-4 fw-medium">
                            Não, Cancelar
                        </a>
                        <button type="submit" class="btn btn-danger px-4 shadow-sm fw-medium">
                            Sim, Confirmar Exclusão
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>