@model IEnumerable<Docker_AspNetCore_MVC_Condominio.Web.Models.UsuarioViewModel>
@{
    ViewData["Title"] = "Gerenciamento de Usuários";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-people-fill text-primary fs-3"></i>
            <h4 class="fw-bold text-secondary m-0">@ViewData["Title"]</h4>
        </div>
        <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm fw-medium">
            <i class="bi bi-person-plus-fill"></i> Adicionar
        </a>
    </div>

    <div class="bg-light p-3 rounded-3 border mb-4">
        <form role="search" method="get" autocomplete="off" class="row g-3 align-items-center">
            <div class="col-md-3">
                <div class="form-floating">
                    <input autofocus type="text" name="username" id="txtUserName" class="form-control" placeholder="Nome de Usuário" value="@ViewData["username"]" />
                    <label for="txtUserName">Nome de Usuário</label>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-floating">
                    <input type="text" name="empresanome" id="txtEmpresaNome" class="form-control" placeholder="Empresa / Condomínio" value="@ViewData["empresanome"]" />
                    <label for="txtEmpresaNome">Empresa / Condomínio</label>
                </div>
            </div>

            <div class="col-md-3">
                <div class="form-floating">
                    <input type="text" name="perfilacesso" id="txtPerfilAcesso" class="form-control" placeholder="Perfil de Acesso" value="@ViewData["perfilacesso"]" />
                    <label for="txtPerfilAcesso">Perfil de Acesso</label>
                </div>
            </div>
            <div class="col-md-auto ms-auto">
                <button type="submit" class="btn btn-primary py-2.5 px-4 shadow-sm fw-medium d-flex align-items-center justify-content-center gap-2">
                    <i class="bi bi-search"></i> Pesquisar
                </button>
            </div>
        </form>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary small fw-bold">
                <tr>
                    <th>Nome de Usuário</th>
                    <th>E-mail Corporativo</th>
                    <th>Empresa / Condomínio</th>
                    <th>Perfil de Acesso</th>
                    <th class="text-end px-3">Ações</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            <i class="bi bi-people-fill fs-3 d-block mb-2"></i>
                            Nenhum registro encontrado.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="fw-semibold text-dark">@item.UserName</span>
                            </td>
                            <td>
                                <span class="text-dark small">@item.Email</span>
                            </td>
                            <td>
                                <i class="bi bi-building text-muted me-1"></i> @item.EmpresaNome
                            </td>
                            <td>
                                <span class="badge @(item.Perfil == "Suporte"
                                    ? "bg-danger-subtle text-danger border border-danger-subtle" : item.Perfil == "Sindico" 
                                    ? "bg-primary-subtle text-primary border border-primary-subtle" : "bg-dark-subtle text-dark border border-dark-subtle") px-3 py-2 fs-6">
                                    @item.Perfil
                                </span>
                            </td>
                            <td class="text-end px-3">
                                <div class="d-flex justify-content-end gap-1">
                                    <a asp-action="DetalharUsuario" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm rounded-2" title="Detalhar Usuário">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="EditarUsuario" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Editar Usuário">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="ExcluirUsuario" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" title="Excluir Usuário">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>