@model Docker_AspNetCore_MVC_Condominio.Web.Models.UsuarioViewModel
@{
    ViewData["Title"] = "Detalhes do Usuário";
    bool isLocked = ViewBag.IsLockedOut ?? false;
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div class="d-flex align-items-center gap-2 text-secondary">
            <i class="bi bi-people text-primary fs-3"></i>
            <h4 class="fw-bold m-0">@ViewData["Title"]</h4>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 border-bottom pb-3">
            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-info-circle me-1"></i> Dados Gerais</h6>
            <div class="row g-3">
                <div class="col-md-4">
                    <small class="text-muted d-block fw-normal">Nome de Usuário (Login)</small>@Model.UserName
                </div>
                <div class="col-md-4">
                    <small class="text-muted d-block fw-normal">E-mail Cadastrado</small>@Model.Email
                </div>
                <div class="col-md-2">
                    <small class="text-muted d-block fw-normal">Status de Acesso</small>
                    <span class="badge bg-danger-subtle @(isLocked ? "text-danger border border-danger " : "text-success border border-success ") shadow-sm px-3 py-2 mt-1 fw-bold fs-6">
                        @(isLocked ? "Conta Bloqueada temporariamente" : "Conta Ativa / Regular")
                    </span>
                </div>
            </div>
        </div>

        <div class="col-12 border-bottom pb-3">
            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-person-badge me-1"></i> Nível de Acesso e Vínculo</h6>
            <div class="row g-3">
                <div class="col-md-4">
                    <small class="text-muted d-block fw-normal">Empresa / Condomínio Designado</small>
                    <div class="mt-1">
                        <i class="bi bi-building text-muted me-1"></i> @Model.EmpresaNome
                    </div>
                </div>
                <div class="col-md-4">
                    <small class="text-muted d-block fw-normal">Perfil de Segurança (Role)</small>
                    <span class="badge bg-dark font-monospace text-uppercase mt-1 px-3 py-1.5 fw-bold fs-6">
                        @Model.Perfil
                    </span>
                </div>
            </div>
        </div>
    </div>
    <div class="d-flex gap-2 mt-1 pt-3">
        <a asp-action="ListarUsuarios" class="btn btn-secondary px-4">
            <i class="bi bi-arrow-left-circle me-1"></i> Voltar para Lista
        </a>
    </div>
</div>