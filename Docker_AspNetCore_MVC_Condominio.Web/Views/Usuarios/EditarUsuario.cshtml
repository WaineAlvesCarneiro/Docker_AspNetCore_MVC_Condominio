@model Docker_AspNetCore_MVC_Condominio.Web.Models.UsuarioViewModel
@{
    ViewData["Title"] = "Editar Usuário";
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex align-items-center gap-2 mb-4 pb-2 border-bottom">
        <i class="bi bi-pencil-square text-primary fs-3"></i>
        <h4 class="fw-bold text-secondary m-0">@ViewData["Title"]</h4>
    </div>

    <form asp-action="EditarUsuario" autocomplete="off">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

        <div class="row g-4">
            <div class="col-12">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-info-circle me-1"></i> Dados Gerais</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input autofocus asp-for="UserName" class="form-control" placeholder="Nome de Usuário" />
                            <label asp-for="UserName">Nome de Usuário</label>
                            <span asp-validation-for="UserName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Email" class="form-control" placeholder="E-mail" />
                            <label asp-for="Email">E-mail Corporativo</label>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-person-badge me-1"></i> Permissões & Organização</h6>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="form-group">
                            <label class="form-label small fw-medium text-muted">Vincular a esta Empresa do Condomínio</label>
                            <select asp-for="CodigoEmpresa" asp-items="ViewBag.EmpresaId" class="form-select py-2-5">
                                <option value="">-- Administração Central (Sem Vínculo Fixo) --</option>
                            </select>
                            <span asp-validation-for="CodigoEmpresa" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="form-group mb-3">
                            <label class="form-label small fw-medium text-muted">Alterar Perfil de Acesso (Role)</label>
                            <select asp-for="Perfil" asp-items="ViewBag.Roles" class="form-select py-2-5">
                                <option value="">-- Selecione um Perfil --</option>
                            </select>
                            <span asp-validation-for="Perfil" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
                <div class="col-12">
                    <h6 class="fw-bold text-primary mb-3"><i class="bi bi-sliders me-1"></i> Diretrizes de Acesso:</h6>
                    <div class="col-4">
                        <div class="form-group">
                            <label class="form-label small fw-medium text-muted">Definir Nova Senha (Opcional)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-muted"><i class="bi bi-key"></i></span>
                                <input type="password" asp-for="NovaSenha" class="form-control py-2-5" placeholder="Deixe em branco para manter a atual" />
                            </div>
                            <span asp-validation-for="NovaSenha" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-light rounded-3 p-3 border mt-4 d-flex justify-content-between align-items-center">
            <div>
                <span class="fw-semibold text-dark small d-block">Segurança de Credenciais</span>
                <small class="text-muted">A senha antiga é protegida por hash. Use o campo acima para alterá-la diretamente ou envie o link.</small>
            </div>
            <a asp-area="Identity" asp-page="/Account/ForgotPassword" class="btn btn-sm btn-outline-dark">
                <i class="bi bi-envelope me-1"></i> Enviar Link de Nova Senha
            </a>
        </div>

        <div class="d-flex gap-2 mt-1 pt-3">
            <button type="submit" class="btn btn-success px-4 shadow-sm fw-medium">
                <i class="bi bi-floppy"></i> Salvar
            </button>
            <a asp-action="ListarUsuarios" asp-route-id="@Model.Id" class="btn btn-secondary px-4 fw-medium">
                <i class="bi bi-x-circle"></i> Cancelar
            </a>
        </div>
    </form>
</div>