@page
@model RegisterModel
@{
    ViewData["Title"] = "Cadastro de Usuário";
    var roles = (List<IdentityRole>)ViewData["roles"]!;
}

<div class="card shadow-sm border-0 rounded-3 p-4 bg-white">
    <div class="d-flex align-items-center gap-2 mb-4 pb-2 border-bottom">
        <i class="bi bi-person-plus-fill text-primary fs-3"></i>
        <h4 class="fw-bold text-secondary m-0">@ViewData["Title"]</h4>
    </div>

    <form asp-route-returnUrl="@Model.ReturnUrl" method="post" autocomplete="off">
        <div class="row g-4">
            <div class="col-12">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-info-circle me-1"></i> Dados Gerais</h6>
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input autofocus asp-for="Input.UserName" class="form-control" placeholder="Nome de Usuário" />
                            <label asp-for="Input.UserName">Nome de Usuário</label>
                            <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating">
                            <input asp-for="Input.Email" class="form-control" placeholder="E-mail" />
                            <label asp-for="Input.Email">E-mail Corporativo</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <h6 class="fw-bold text-primary mb-3"><i class="bi bi-person-badge me-1"></i> Permissões & Organização</h6>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="form-group">
                            <label class="form-label small fw-medium text-muted">Vincular a Empresa do Condomínio</label>
                            <select asp-for="Input.CodigoEmpresa" asp-items="ViewBag.EmpresaId" class="form-select py-2-5">
                                <option value="">-- Selecione uma Empresa --</option>
                            </select>
                            <span asp-validation-for="Input.CodigoEmpresa" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="form-group mb-3">
                            <label class="form-label small fw-medium text-muted">Definir Perfil de Acesso (Role)</label>
                            <select asp-for="Input.Name" asp-items='new SelectList(roles, "Id", "Name")' class="form-select py-2-5">
                                <option value="">-- Selecione um Perfil --</option>
                            </select>
                            <span asp-validation-for="Input.Name" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12">
            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-sliders me-1"></i> Diretrizes de Acesso:</h6>
            <div class="row g-3">
                <div class="col-md-3">
                    <div class="form-floating">
                        <input type="password" asp-for="Input.Password" class="form-control" placeholder="Senha" />
                        <label asp-for="Input.Password">Senha de Acesso</label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-floating">
                        <input type="password" asp-for="Input.ConfirmPassword" class="form-control" placeholder="Confirmar Senha" />
                        <label asp-for="Input.ConfirmPassword">Confirmar Senha</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>
        <div class="d-flex gap-2 mt-3 pt-3 border-top">
            <button type="submit" class="btn btn-success px-4 shadow-sm">
                <i class="bi bi-floppy"></i> Salvar
            </button>
            <a asp-area="" asp-controller="Usuarios" asp-action="ListarUsuarios" class="btn btn-secondary px-4">
                <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}