@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Alterar senha";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<h4 class="fw-bold text-secondary mb-3">@ViewData["Title"]</h4>
<partial name="_StatusMessage" for="StatusMessage" />

<div class="row">
    <div class="col-xl-6 col-lg-8">
        <form id="change-password-form" method="post">
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <div class="form-floating mb-3">
                <input type="password" asp-for="Input.OldPassword" class="form-control" placeholder="Senha Atual" />
                <label asp-for="Input.OldPassword">Senha Atual</label>
                <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-3">
                <input type="password" asp-for="Input.NewPassword" class="form-control" placeholder="Nova Senha" />
                <label asp-for="Input.NewPassword">Nova Senha</label>
                <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-4">
                <input type="password" asp-for="Input.ConfirmPassword" class="form-control" placeholder="Confirmar Nova Senha" />
                <label asp-for="Input.ConfirmPassword">Confirmar Nova Senha</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary px-4 shadow-sm">
                <i class="bi bi-key me-1"></i> Alterar Senha
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}