@page
@model IndexModel
@{
    ViewData["Title"] = "Dados do Usuário";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h4 class="fw-bold text-secondary mb-3">@ViewData["Title"]</h4>
<partial name="_StatusMessage" model="Model.StatusMessage" />

<div class="row">
    <div class="col-xl-6 col-lg-8">
        <form id="profile-form" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

            <div class="form-group mb-3">
                <label asp-for="Username" class="form-label text-muted small fw-semibold">Usuário</label>
                <input asp-for="Username" class="form-control bg-light" disabled />
            </div>

            <div class="form-floating mb-4">
                <input asp-for="Input.PhoneNumber" class="form-control" placeholder="Telefone / Celular" autocomplete="off" />
                <label asp-for="Input.PhoneNumber">Telefone / Celular</label>
                <span asp-validation-for="Input.PhoneNumber" class="text-danger small"></span>
            </div>

            <button id="update-profile-button" type="submit" class="btn btn-success px-4 shadow-sm">
                <i class="bi bi-floppy me-1"></i> Salvar Alterações
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}