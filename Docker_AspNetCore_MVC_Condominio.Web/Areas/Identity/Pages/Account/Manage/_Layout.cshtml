@{
    if (ViewData.TryGetValue("ParentLayout", out var parentLayout))
    {
        Layout = (string)parentLayout!;
    }
    else
    {
        Layout = "/Areas/Identity/Pages/_Layout.cshtml";
    }
}

<div class="container py-4">
    <div class="row g-4">
        <div class="col-lg-3 col-md-4">
            <div class="card shadow-sm border-0 rounded-3 p-3 bg-white">
                <h5 class="fw-bold text-secondary mb-3 pb-2 border-bottom">
                    <i class="bi bi-person-gear me-2 text-primary"></i>Minha Conta
                </h5>
                <partial name="_ManageNav" />
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="card shadow-sm border-0 rounded-3 p-4 bg-white" style="min-height: 400px;">
                @RenderBody()
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @RenderSection("Scripts", required: false)
}