@page
@model LoginModel
@{
    ViewData["Title"] = "Conecte-se";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-4 col-sm-8">
        <div class="card shadow border-0 rounded-3">
            <div class="card-body p-4">

                <div class="text-center mb-4">
                    <div class="display-5 text-primary mb-2">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                    <h4 class="fw-bold text-secondary">Acesse sua Conta</h4>
                    <small class="text-muted">Informe seu usuário e senha abaixo</small>
                </div>

                <form id="account" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                    <div class="form-floating mb-3">
                        <input autofocus asp-for="Input.UserName" class="form-control" placeholder="Usuário" autocomplete="off" />
                        <label asp-for="Input.UserName">
                            <i class="bi bi-person me-1"></i> Usuário
                        </label>
                        <span asp-validation-for="Input.UserName" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input type="password" asp-for="Input.Password" class="form-control" placeholder="Senha" autocomplete="off" />
                        <label asp-for="Input.Password">
                            <i class="bi bi-key me-1"></i> Senha
                        </label>
                        <span asp-validation-for="Input.Password" class="text-danger small"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary btn-lg shadow-sm">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Entrar
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}