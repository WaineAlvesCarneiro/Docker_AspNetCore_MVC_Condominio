@page
@model LogoutModel
@{
    ViewData["Title"] = "Confirmar Saída";
}

<div class="row justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="col-md-5 col-sm-9">
        <div class="card shadow border-0 rounded-3 text-center">
            <div class="card-body p-5">
                <div class="display-4 text-warning mb-3">
                    <i class="bi bi-exclamation-triangle"></i>
                </div>
                <h4 class="fw-bold text-secondary mb-2">Deseja realmente sair?</h4>
                <p class="text-muted small mb-4">Você precisará informar suas credenciais novamente para acessar o painel do condomínio.</p>

                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                    <div class="d-flex justify-content-center gap-3">
                        <button type="button" class="btn btn-light px-4" onclick="history.back()">
                            Não, Voltar
                        </button>
                        <button type="submit" class="btn btn-danger px-4 shadow-sm">
                            Sim, Sair
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>